# NeuroBridge Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection String
# Get free cloud DB at: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/neurobridge

# JWT Secret Key (use any long random string)
JWT_SECRET=neurobridge_super_secret_key_change_this_in_production

# Server Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
